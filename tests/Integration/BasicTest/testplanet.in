# Planet parameters (modeled after TRAPPIST-1b)
sName                     planet
saModules                 atmesc

# Physical Properties (from Agol et al. [2021])
dMass                     -1.017
dRadius                   -1.121

# AtmEsc Properties
dXFrac                    1.0
dSurfWaterMass            -20
dEnvelopeMass             0.0
sWaterLossModel           ls16
bInstantO2Sink            0
sAtmXAbsEffH2OModel       bolmont16

# Orbital Properties
dEcc                       0.0062
dOrbPeriod                 -1.5

saOutputOrder Time -SurfWaterMass -OxygenMass
