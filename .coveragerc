[run]
source = vconverge
omit =
    */tests/*
    */test_*
    */__pycache__/*
    */vconverge_version.py
concurrency = multiprocessing
parallel = True
sigterm = True

[report]
precision = 2
show_missing = True
skip_covered = False

exclude_lines =
    pragma: no cover
    def __repr__
    raise AssertionError
    raise NotImplementedError
    if __name__ == .__main__.:
    @abstract

[html]
directory = htmlcov
